# Copy to .env before running docker compose.
# PEM values must be a single line with literal "\n" escape sequences.

KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change-me-admin-password
KEYCLOAK_WALLET_OWNER_USER=wallet-owner-1
KEYCLOAK_WALLET_OWNER_PASSWORD=change-me-wallet-owner-password
KEYCLOAK_WALLET_OWNER_USER_ID=KYC-1234
KEYCLOAK_NOMINEE_USER=wallet-nominee
KEYCLOAK_NOMINEE_PASSWORD=change-me-wallet-nominee-password
KEYCLOAK_FI_CLIENT_ID=fi-client
KEYCLOAK_FI_BROWSER_CLIENT_ID=fi-browser-client
KEYCLOAK_FI2_CLIENT_ID=fi-client-2
KEYCLOAK_FI_USER_1=fi-analyst-1
KEYCLOAK_FI_PASSWORD_1=change-me-fi-analyst-1-password
KEYCLOAK_FI_USER_2=fi-analyst-2
KEYCLOAK_FI_PASSWORD_2=change-me-fi-analyst-2-password

JWT_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nREPLACE_WITH_ISSUER_ES256_PRIVATE_KEY\n-----END PRIVATE KEY-----
CONSENT_SIGNING_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nREPLACE_WITH_CONSENT_ES256_PRIVATE_KEY\n-----END PRIVATE KEY-----
VAULT_ENCRYPTION_KEY_BASE64=REPLACE_WITH_BASE64_32_BYTE_KEY

ISSUER_ADMIN_CLIENT_SECRET=change-me-issuer-admin-secret
CONSENT_SERVICE_CLIENT_SECRET=change-me-consent-service-secret
REVIEW_SERVICE_CLIENT_SECRET=change-me-review-service-secret
KEYCLOAK_FI_CLIENT_SECRET=change-me-fi-client-secret
KEYCLOAK_FI2_CLIENT_SECRET=change-me-fi-client-2-secret
VITE_FI_KEYCLOAK_CLIENT_ID=fi-browser-client
VITE_FI_CLIENT_ID=fi-client
VITE_FI2_CLIENT_ID=fi-client-2
VITE_WALLET_OWNER_USER_ID=KYC-1234
VITE_WALLET_SECONDARY_USER_ID=KYC-5678
VITE_CONSOLE_DEBUG_LOGS=1
VITE_COMMAND_PORTAL_ADMIN_LOGIN_REQUIRED=0

# Logging controls for local debugging
LOG_LEVEL=info
# Set 1 only for deep local debugging (may log request/response bodies)
LOG_INCLUDE_BODIES=0
# Set 1 to include request headers in HTTP logs (authorization/cookies stay masked)
LOG_HTTP_INCLUDE_HEADERS=0
# Set 1 for indented multi-line JSON logs (easier to read in local dev)
LOG_PRETTY_JSON=1
# Set 1 to hide /v1/health request logs
LOG_SKIP_HEALTHCHECKS=1
# Set to debug to include successful request logs at debug level
LOG_HTTP_SUCCESS_LEVEL=info

# Optional consent expiry override (seconds, default 300)
CONSENT_TTL_SECONDS=300

# Optional review periodicity overrides (years)
REVIEW_PERIOD_HIGH_YEARS=2
REVIEW_PERIOD_MEDIUM_YEARS=8
REVIEW_PERIOD_LOW_YEARS=10
